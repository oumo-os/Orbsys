# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://orbsys_app:change_me@localhost:5432/orbsys
DATABASE_URL_SYNC=postgresql://orbsys_app:change_me@localhost:5432/orbsys
DATABASE_URL_INTEGRITY=postgresql+asyncpg://orbsys_integrity:change_me@localhost:5432/orbsys
DATABASE_URL_INFERENTIAL=postgresql+asyncpg://orbsys_inferential:change_me@localhost:5432/orbsys
DATABASE_URL_INSIGHT=postgresql+asyncpg://orbsys_insight:change_me@localhost:5432/orbsys
DATABASE_URL_BLIND=postgresql+asyncpg://orbsys_blind:change_me@localhost:5432/orbsys

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Event Bus ────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── LLM (Insight Engine) ─────────────────────────────────────────────────────
LLM_BACKEND=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o

# ── Object Store ─────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=orbsys
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
BLIND_API_PORT=8001
CORS_ORIGINS=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Orb Sys

# ── Blind Review API ──────────────────────────────────────────────────────────
NEXT_PUBLIC_BLIND_API_URL=http://localhost:8001
